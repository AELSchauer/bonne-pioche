<section class="mb-7.5 last:mb-0">
  <h2 class="m-0 mb-4 text-[15px] font-bold">Basics</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
    <div class="sm:col-span-2">
      <%= f.label :name, "Component name", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.text_field :name, placeholder: "e.g. Aged cheddar wedge, 150g", class: "field-input", required: true %>
    </div>

    <div class="sm:col-span-2">
      <span class="block mb-1.5 text-[13px] font-semibold text-text">Primary SKU</span>
      <% default_sku_prefix = @component.persisted? ? @component.sku_prefix : (@selected_sku_prefix.presence || ComponentsController::SKU_PREFIXES.keys.first) %>
      <div class="flex items-center gap-2">
        <select class="field-input w-[180px]" id="component_sku_prefix" name="component[sku_prefix]">
          <% ComponentsController::SKU_PREFIXES.each do |code, label| %>
            <option value="<%= code %>" <%= "selected" if code == default_sku_prefix %>><%= "#{code} — #{label}" %></option>
          <% end %>
        </select>
        <% if @component.persisted? %>
          <span class="text-sm text-text-faint">-<%= @component.sku_number %></span>
        <% end %>
      </div>
      <% if @component.persisted? %>
        <p class="mt-1.5 text-xs text-text-faint">The SKU number is assigned at creation and can't be changed.</p>
      <% else %>
        <p class="mt-1.5 text-xs text-text-faint">A unique number is assigned automatically when you save.</p>
      <% end %>
    </div>

    <div>
      <%= f.label :unit_of_measure, "Unit of measure", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.select :unit_of_measure, Component::UNIT_LABELS.map { |value, label| [ label, value ] }, {}, id: "component_unit_of_measure", class: "field-input" %>
      <p class="mt-1.5 text-xs text-text-faint">ea &middot; pack &middot; set &middot; g &middot; L</p>
    </div>

    <div>
      <%= f.label :status, "Status", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.select :status, ComponentsController::STATUSES.map { |value, label| [ label, value ] }, {}, id: "component_status", class: "field-input" %>
      <p class="mt-1.5 text-xs text-text-faint">Draft &middot; Active &middot; Inactive &middot; Archived</p>
    </div>

    <div>
      <%= f.label :supplier_id, "Supplier", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.select :supplier_id, @suppliers.map { |supplier| [ supplier.name, supplier.id ] }, { include_blank: "— None —" }, id: "component_supplier_id", class: "field-input" %>
    </div>
  </div>
</section>

<section class="mb-7.5 last:mb-0">
  <h2 class="m-0 mb-4 text-[15px] font-bold">Pricing</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
    <% if @component.persisted? %>
      <div>
        <span class="block mb-1.5 text-[13px] font-semibold text-text">Cost per unit</span>
        <% unit_cost_cents = @component.unit_cost_cents %>
        <input class="field-input field-input-readonly" type="text" readonly tabindex="-1"
               value="<%= unit_cost_cents ? number_to_currency(unit_cost_cents / 100.0) : "—" %>">
        <p class="mt-1.5 text-xs text-text-faint">The highest cost/unit across this component's supplier SKUs.</p>
      </div>
    <% end %>

    <div>
      <%= f.label :msrp, "MSRP per unit", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.number_field :msrp, value: @component.msrp, min: 0, step: 0.01, class: "field-input" %>
    </div>
  </div>
</section>

<section class="mb-7.5 last:mb-0">
  <h2 class="m-0 mb-4 text-[15px] font-bold">Attributes</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
    <div>
      <span class="block mb-1.5 text-[13px] font-semibold text-text">Restrictions</span>
      <div class="flex flex-wrap gap-2">
        <% @restriction_options.each do |restriction_name| %>
          <label class="chip-toggle">
            <input type="checkbox" name="component[restrictions][]" value="<%= restriction_name.id %>"
                   <%= "checked" if @component.restrictions.any? { |r| r.restriction_name_id == restriction_name.id } %>>
            <span><%= restriction_name.name %></span>
          </label>
        <% end %>
      </div>
      <p class="mt-1.5 text-xs text-text-faint">Dietary or handling qualities this component satisfies.</p>
    </div>

    <div>
      <span class="block mb-1.5 text-[13px] font-semibold text-text">Image</span>
      <div class="flex items-center justify-center min-h-24 border-[1.5px] border-dashed border-border-strong rounded-md bg-surface-alt cursor-pointer text-center p-3 data-[over=true]:border-accent data-[over=true]:bg-accent-soft"
           data-controller="dropzone" data-action="dragover->dropzone#over dragleave->dropzone#leave drop->dropzone#drop click->dropzone#browse">
        <%= f.file_field :image, accept: "image/*", hidden: true,
              data: { dropzone_target: "input", action: "change->dropzone#change" } %>
        <div class="flex flex-col items-center gap-2" data-dropzone-target="preview">
          <% if @component.image.attached? %>
            <%= image_tag @component.image, class: "max-h-16 max-w-full rounded-sm object-cover" %>
            <span class="text-xs text-text-muted"><%= @component.image.filename %></span>
          <% else %>
            <span class="text-[13px] text-text-faint">drop image or browse</span>
          <% end %>
        </div>
      </div>
      <% if @component.image.attached? %>
        <label class="flex items-center gap-2 mt-2 text-[13px] text-text-muted">
          <input type="checkbox" name="component[remove_image]" value="1">
          Remove current image
        </label>
      <% end %>
    </div>

    <div class="sm:col-span-2">
      <label class="block mb-1.5 text-[13px] font-semibold text-text" for="component_notes">Notes</label>
      <%= text_area_tag "component[notes]", nil, id: "component_notes", class: "field-input resize-y min-h-20", rows: 4 %>
    </div>
  </div>
</section>
