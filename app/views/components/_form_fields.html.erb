<section class="mb-7.5 last:mb-0">
  <h2 class="m-0 mb-4 text-[15px] font-bold">Basics</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
    <div class="sm:col-span-2">
      <%= f.label :name, "Component name", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.text_field :name, placeholder: "e.g. Aged cheddar wedge, 150g", class: "field-input", required: true %>
    </div>

    <div class="sm:col-span-2">
      <span class="block mb-1.5 text-[13px] font-semibold text-text">Primary SKU</span>
      <% if @component.persisted? %>
        <input class="field-input field-input-readonly" type="text" readonly tabindex="-1" value="<%= @component.sku %>">
        <p class="mt-1.5 text-xs text-text-faint">Assigned at creation; can't be changed.</p>
      <% else %>
        <% default_sku_prefix = @selected_sku_prefix.presence || ComponentsController::SKU_PREFIXES.keys.first %>
        <div class="flex gap-2.5" data-controller="sku" data-sku-next-numbers-value="<%= @next_sku_numbers.to_json %>">
          <select class="field-input flex-none w-[180px]" id="component_sku_prefix" name="component[sku_prefix]"
                  data-sku-target="prefix" data-action="change->sku#updateNumber">
            <% ComponentsController::SKU_PREFIXES.each do |code, label| %>
              <option value="<%= code %>" <%= "selected" if code == default_sku_prefix %>><%= "#{code} — #{label}" %></option>
            <% end %>
          </select>
          <input class="field-input field-input-readonly flex-1" type="text" id="component_sku_number" readonly tabindex="-1"
                 value="<%= @next_sku_numbers[default_sku_prefix] %>" data-sku-target="number">
        </div>
        <p class="mt-1.5 text-xs text-text-faint">Sequential per prefix; assigned automatically.</p>
      <% end %>
    </div>

    <% selected_category = @component.subcategory&.category %>
    <% subcategory_options = (selected_category&.subcategories || []).map { |s| [ s.name, s.id ] } %>
    <% subcategories_by_category = @categories.each_with_object({}) { |category, hash| hash[category.id] = category.subcategories.order(:name).map { |s| { value: s.id, label: s.name } } } %>

    <div data-controller="nested-select" data-nested-select-options-value="<%= subcategories_by_category.to_json %>">
      <label class="block mb-1.5 text-[13px] font-semibold text-text" for="component_category_id">Category</label>
      <select class="field-input" id="component_category_id" data-nested-select-target="parent"
              data-action="change->nested-select#updateChild" required>
        <option value="">Select category</option>
        <% @categories.each do |category| %>
          <option value="<%= category.id %>" <%= "selected" if category == selected_category %>><%= category.name %></option>
        <% end %>
      </select>
    </div>

    <div>
      <%= f.label :subcategory_id, "Subcategory", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.select :subcategory_id, options_for_select(subcategory_options, @component.subcategory_id),
            { include_blank: "Select subcategory" },
            id: "component_subcategory_id", class: "field-input", data: { nested_select_target: "child" }, required: true %>
    </div>

    <div>
      <label class="block mb-1.5 text-[13px] font-semibold text-text" for="component_unit">Unit of measure</label>
      <%= select_tag "component[unit]", options_for_select(ComponentsController::UNITS, "ea"), id: "component_unit", class: "field-input" %>
      <p class="mt-1.5 text-xs text-text-faint">ea &middot; pack &middot; set &middot; g &middot; L</p>
    </div>

    <div>
      <%= f.label :status, "Status", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.select :status, ComponentsController::STATUSES.map { |value, label| [ label, value ] }, {}, id: "component_status", class: "field-input" %>
      <p class="mt-1.5 text-xs text-text-faint">Draft &middot; Active &middot; Inactive &middot; Archived</p>
    </div>
  </div>
</section>

<section class="mb-7.5 last:mb-0">
  <h2 class="m-0 mb-4 text-[15px] font-bold">Attributes</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
    <div>
      <span class="block mb-1.5 text-[13px] font-semibold text-text">Restrictions</span>
      <div class="flex flex-wrap gap-2">
        <% @restriction_options.each do |key| %>
          <label class="chip-toggle">
            <input type="checkbox" name="component[restrictions][]" value="<%= key %>"
                   <%= "checked" if @component.restrictions.any? { |r| r.name == key } %>>
            <span><%= ComponentsController::RESTRICTION_LABELS.fetch(key, key.humanize) %></span>
          </label>
        <% end %>
      </div>
      <p class="mt-1.5 text-xs text-text-faint">Dietary or handling qualities this component satisfies.</p>
    </div>

    <div>
      <span class="block mb-1.5 text-[13px] font-semibold text-text">Image</span>
      <div class="flex items-center justify-center min-h-24 border-[1.5px] border-dashed border-border-strong rounded-md bg-surface-alt cursor-pointer text-center p-3 data-[over=true]:border-accent data-[over=true]:bg-accent-soft"
           data-controller="dropzone" data-action="dragover->dropzone#over dragleave->dropzone#leave drop->dropzone#drop click->dropzone#browse">
        <input type="file" name="component[image]" accept="image/*"
               data-dropzone-target="input" data-action="change->dropzone#change" hidden>
        <div class="flex flex-col items-center gap-2" data-dropzone-target="preview">
          <span class="text-[13px] text-text-faint">drop image or browse</span>
        </div>
      </div>
    </div>

    <div class="sm:col-span-2">
      <label class="block mb-1.5 text-[13px] font-semibold text-text" for="component_notes">Notes</label>
      <%= text_area_tag "component[notes]", nil, id: "component_notes", class: "field-input resize-y min-h-20", rows: 4 %>
    </div>
  </div>
</section>
