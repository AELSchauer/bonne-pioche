<% content_for :title, "Components · Bonne Pioche" %>

<div class="min-h-screen bg-bg">
  <%= render "shared/topbar" %>

  <main class="max-w-[1280px] mx-auto px-6 pt-8 pb-18">
    <p class="mb-4.5 text-[13px] text-text-muted">
      <span class="text-text font-semibold">Components</span>
    </p>

    <% if notice %>
      <div class="mb-5 px-4 py-2.75 rounded-sm text-[13.5px] border border-[#cfe0c8] bg-accent-soft text-accent-dark"><%= notice %></div>
    <% end %>

    <div class="flex items-start justify-between gap-5 mb-5.5">
      <div>
        <h1 class="m-0 text-[26px] font-bold tracking-tight">Components</h1>
        <p class="mt-1.5 mb-0 text-text-muted text-sm">Reusable parts that can be added to any gift box assembly.</p>
      </div>
      <div class="flex items-center gap-2.5 flex-wrap justify-end">
        <%= link_to "+ Add component", new_component_path, class: "btn btn-primary" %>
      </div>
    </div>

    <div class="card card-flush">
      <% if @components.any? %>
        <div class="overflow-x-auto">
          <table class="w-full min-w-[560px] border-collapse">
            <thead>
              <tr>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border">Name</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border">Category</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border">Restrictions</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border">Status</th>
                <th class="text-left px-5 py-3 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border"></th>
              </tr>
            </thead>
            <tbody>
              <% @components.each do |component| %>
                <tr class="hover:bg-surface-alt">
                  <td class="px-5 py-3.5 text-[13.5px] border-b border-border align-middle font-semibold text-text"><%= component.name %></td>
                  <td class="px-5 py-3.5 text-[13.5px] border-b border-border align-middle"><%= "#{component.subcategory.category.name} › #{component.subcategory.name}" %></td>
                  <td class="px-5 py-3.5 text-[13.5px] border-b border-border align-middle">
                    <% if component.restrictions.any? %>
                      <div class="flex flex-wrap gap-1.5">
                        <% component.restrictions.each do |exclusion| %>
                          <span class="chip"><%= exclusion.name.humanize %></span>
                        <% end %>
                      </div>
                    <% else %>
                      <span class="text-text-faint">—</span>
                    <% end %>
                  </td>
                  <td class="px-5 py-3.5 text-[13.5px] border-b border-border align-middle">
                    <span class="status-badge <%= "status-badge-active" if component.status == "active" %>"><%= component.status.humanize %></span>
                  </td>
                  <td class="px-5 py-3.5 text-[13.5px] border-b border-border align-middle">
                    <%= link_to "Edit", edit_component_path(component), class: "btn btn-secondary btn-sm" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="flex flex-col items-center gap-2 text-center py-14 px-6">
          <p class="m-0 text-base font-bold">No components yet</p>
          <p class="mb-2 text-text-muted text-[13.5px]">Add your first reusable part to start building gift box assemblies.</p>
          <%= link_to "+ Add component", new_component_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </main>
</div>
