<% content_for :title, "Edit component · Bonne Pioche" %>

<p class="mb-4.5 flex items-center gap-2 text-[13px] text-text-muted">
  <%= link_to "Components", components_path %>
  <span class="text-text-faint">&rsaquo;</span>
  <span class="text-text font-semibold">Edit component</span>
</p>

<% if notice %>
  <div class="mb-5 px-4 py-2.75 rounded-sm text-[13.5px] border border-[#cfe0c8] bg-accent-soft text-accent-dark"><%= notice %></div>
<% end %>

<%= form_with model: @component, url: component_path(@component), method: :patch,
      data: { turbo: false, controller: "form-guard", action: "input->form-guard#markDirty change->form-guard#markDirty" } do |f| %>

  <div class="flex items-start justify-between gap-5 mb-5.5">
    <div>
      <h1 class="m-0 text-[26px] font-bold tracking-tight">Edit component</h1>
      <p class="mt-1.5 mb-0 text-text-muted text-sm">A reusable part that can be added to any gift box assembly.</p>
    </div>
    <div class="flex items-center gap-2.5 flex-wrap justify-end">
      <%= link_to "Cancel", components_path, class: "btn btn-tertiary", data: { action: "form-guard#confirmCancel" } %>
      <%= f.submit "Save component", class: "btn btn-primary" %>
    </div>
  </div>

  <% if @component.errors.any? %>
    <div class="mb-5 px-4 py-2.75 rounded-sm text-[13.5px] border border-[#ecc8be] bg-danger-soft text-danger">
      <%= @component.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="card">
    <%= render "form_fields", f: f %>
  </div>

  <div class="flex items-center justify-between gap-4 mt-5.5 px-5 py-4 bg-surface border border-border rounded-lg flex-wrap sm:flex-nowrap">
    <span class="text-[13px] text-text-muted">Saved as a reusable component in the library.</span>
    <div class="flex items-center gap-2.5 flex-wrap justify-end">
      <%= link_to "Cancel", components_path, class: "btn btn-tertiary", data: { action: "form-guard#confirmCancel" } %>
      <%= f.submit "Save component", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
