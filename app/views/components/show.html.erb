<% content_for :title, "#{@component.name} · Bonne Pioche" %>

<div class="min-h-screen bg-bg">
  <%= render "shared/topbar" %>

  <main class="max-w-[1280px] mx-auto px-6 pt-8 pb-18">
    <p class="mb-4.5 flex items-center gap-2 text-[13px] text-text-muted">
      <%= link_to "Components", components_path %>
      <span class="text-text-faint">&rsaquo;</span>
      <span class="text-text font-semibold"><%= @component.name %></span>
    </p>

    <% if notice %>
      <div class="mb-5 px-4 py-2.75 rounded-sm text-[13.5px] border border-[#cfe0c8] bg-accent-soft text-accent-dark"><%= notice %></div>
    <% end %>

    <div class="flex items-start justify-between gap-5 mb-5.5">
      <div>
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="m-0 text-[26px] font-bold tracking-tight"><%= @component.name %></h1>
          <span class="status-badge <%= "status-badge-active" if @component.status == "active" %>"><%= @component.status.humanize %></span>
        </div>
        <p class="mt-1.5 mb-0 text-text-muted text-sm"><%= @component.sku %></p>
      </div>
      <div class="flex items-center gap-2.5 flex-wrap justify-end">
        <%= link_to "Back", components_path, class: "btn btn-tertiary" %>
        <%= link_to "Clone", new_component_path(clone_from: @component.id), class: "btn btn-secondary" %>
        <%= link_to "Edit", edit_component_path(@component), class: "btn btn-primary" %>
      </div>
    </div>

    <div class="card">
      <section class="mb-7.5 last:mb-0">
        <h2 class="m-0 mb-4 text-[15px] font-bold">Basics</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
          <div>
            <span class="block mb-1 text-xs font-bold uppercase tracking-wide text-text-faint">Primary SKU</span>
            <span class="text-sm text-text"><%= @component.sku %></span>
          </div>

          <div>
            <span class="block mb-1 text-xs font-bold uppercase tracking-wide text-text-faint">Category</span>
            <span class="text-sm text-text"><%= "#{@component.subcategory.category.name} › #{@component.subcategory.name}" %></span>
          </div>

          <div>
            <span class="block mb-1 text-xs font-bold uppercase tracking-wide text-text-faint">Status</span>
            <span class="status-badge <%= "status-badge-active" if @component.status == "active" %>"><%= @component.status.humanize %></span>
          </div>
        </div>
      </section>

      <section class="mb-7.5 last:mb-0">
        <h2 class="m-0 mb-4 text-[15px] font-bold">Attributes</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
          <div>
            <span class="block mb-1.5 text-xs font-bold uppercase tracking-wide text-text-faint">Restrictions</span>
            <% if @component.restrictions.any? %>
              <div class="flex flex-wrap gap-1.5">
                <% @component.restrictions.each do |restriction| %>
                  <span class="chip"><%= restriction.name.humanize %></span>
                <% end %>
              </div>
            <% else %>
              <span class="text-sm text-text-faint">None</span>
            <% end %>
          </div>

          <div>
            <span class="block mb-1.5 text-xs font-bold uppercase tracking-wide text-text-faint">Image</span>
            <% if @component.image.attached? %>
              <%= image_tag @component.image, class: "max-h-40 max-w-full rounded-md border border-border object-cover" %>
            <% else %>
              <span class="text-sm text-text-faint">No image</span>
            <% end %>
          </div>
        </div>
      </section>
    </div>
  </main>
</div>
