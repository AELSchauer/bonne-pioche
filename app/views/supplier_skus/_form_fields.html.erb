<section class="mb-7.5 last:mb-0">
  <h2 class="m-0 mb-4 text-[15px] font-bold">Basics</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
    <div>
      <%= f.label :name, "SKU name", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.text_field :name, placeholder: "e.g. Case of 12 mugs", class: "field-input", required: true %>
    </div>

    <div>
      <%= f.label :sku, "SKU code", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.text_field :sku, placeholder: "Supplier's catalog code (optional)", class: "field-input" %>
    </div>
  </div>
</section>

<section class="mb-7.5 last:mb-0">
  <h2 class="m-0 mb-4 text-[15px] font-bold">Wholesale pricing</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
    <div>
      <%= f.label :wholesale_cost, "Wholesale cost", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.number_field :wholesale_cost, value: @supplier_sku.wholesale_cost, min: 0, step: 0.01, class: "field-input" %>
    </div>

    <div>
      <%= f.label :wholesale_quantity, "Quantity per purchase", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.number_field :wholesale_quantity, min: 1, class: "field-input" %>
    </div>

    <div class="sm:col-span-2">
      <%= f.label :wholesale_url, "Wholesale URL", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.text_field :wholesale_url, placeholder: "https://…", class: "field-input" %>
    </div>
  </div>
</section>

<section class="mt-2" data-controller="nested-fields">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-[15px] font-bold">Components</h2>
    <button type="button" class="btn btn-secondary btn-sm" data-action="click->nested-fields#add">+ Add component</button>
  </div>

  <% active_components = @supplier_sku.supplier_sku_components.reject(&:marked_for_destruction?) %>

  <div class="overflow-x-auto <%= "hidden" unless active_components.any? %>" data-nested-fields-target="tableWrap">
    <table class="w-full min-w-[420px] border-collapse">
      <thead>
        <tr>
          <th class="text-left px-3 py-2 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border">Component</th>
          <th class="text-left px-3 py-2 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border w-24">Qty</th>
          <th class="px-3 py-2 bg-surface-alt border-b border-border w-20"></th>
        </tr>
      </thead>
      <tbody data-nested-fields-target="list">
        <%= f.fields_for :supplier_sku_components do |sc| %>
          <%= render "component_fields", sc: sc %>
        <% end %>
      </tbody>
    </table>
  </div>

  <p class="text-[13px] text-text-faint mt-2 <%= "hidden" if active_components.any? %>" data-nested-fields-target="empty">
    No components added yet.
  </p>

  <template data-nested-fields-target="template">
    <%= f.fields_for :supplier_sku_components, SupplierSkuComponent.new, child_index: "NEW_RECORD" do |sc| %>
      <%= render "component_fields", sc: sc %>
    <% end %>
  </template>
</section>
