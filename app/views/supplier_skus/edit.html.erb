<% content_for :title, "Edit #{@supplier_sku.name} · #{@supplier.name} · Bonne Pioche" %>

<p class="mb-4.5 flex items-center gap-2 text-[13px] text-text-muted">
  <%= link_to "Suppliers", suppliers_path %>
  <span class="text-text-faint">&rsaquo;</span>
  <%= link_to @supplier.name, supplier_path(@supplier) %>
  <span class="text-text-faint">&rsaquo;</span>
  <%= link_to "Edit SKUs", supplier_supplier_skus_path(@supplier) %>
  <span class="text-text-faint">&rsaquo;</span>
  <span class="text-text font-semibold"><%= @supplier_sku.name %></span>
</p>

<%= form_with model: @supplier_sku, scope: :supplier_sku, url: supplier_supplier_sku_path(@supplier, @supplier_sku), method: :patch,
      data: { controller: "form-guard", action: "input->form-guard#markDirty change->form-guard#markDirty" } do |f| %>

  <div class="flex items-start justify-between gap-5 mb-5.5">
    <div>
      <h1 class="m-0 text-[26px] font-bold tracking-tight"><%= @supplier_sku.name %></h1>
      <p class="mt-1.5 mb-0 text-text-muted text-sm">A purchasable SKU from <%= @supplier.name %> and the components it contains.</p>
    </div>
    <div class="flex items-center gap-2.5 flex-wrap justify-end">
      <%= link_to "Cancel", supplier_supplier_skus_path(@supplier), class: "btn btn-tertiary", data: { action: "form-guard#confirmCancel" } %>
      <%= f.submit "Save SKU", class: "btn btn-primary" %>
    </div>
  </div>

  <% if @supplier_sku.errors.any? %>
    <div class="mb-5 px-4 py-2.75 rounded-sm text-[13.5px] border border-[#ecc8be] bg-danger-soft text-danger">
      <%= @supplier_sku.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="card">
    <%= render "form_fields", f: f %>
  </div>

  <div class="flex items-center justify-between gap-4 mt-5.5 px-5 py-4 bg-surface border border-border rounded-lg flex-wrap sm:flex-nowrap">
    <span class="text-[13px] text-text-muted">Saved to <%= @supplier.name %>.</span>
    <div class="flex items-center gap-2.5 flex-wrap justify-end">
      <%= link_to "Cancel", supplier_supplier_skus_path(@supplier), class: "btn btn-tertiary", data: { action: "form-guard#confirmCancel" } %>
      <%= f.submit "Save SKU", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
