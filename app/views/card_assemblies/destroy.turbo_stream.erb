<%= turbo_stream.remove "card_assembly_#{@card_assembly.id}" %>

<%= turbo_stream.replace "card_assemblies_empty" do %>
  <%= render "cards/empty_state", deck: @deck, card: @card, card_assemblies_count: @card.card_assemblies.count %>
<% end %>

<%= turbo_stream.update "card_assemblies_count_label", "Gift Assemblies (#{@card.card_assemblies.count})" %>
<%= turbo_stream.update "rail_card_count_#{@card.id}", @card.card_assemblies.count %>
