<% content_for :title, "Assemblies · Bonne Pioche" %>

<p class="mb-4.5 text-[13px] text-text-muted">
  <span class="text-text font-semibold">Assemblies</span>
</p>

<% if notice %>
  <div class="mb-5 px-4 py-2.75 rounded-sm text-[13.5px] border border-[#cfe0c8] bg-accent-soft text-accent-dark"><%= notice %></div>
<% end %>

<div class="flex items-start justify-between gap-5 mb-5.5">
  <div>
    <h1 class="m-0 text-[26px] font-bold tracking-tight">Assemblies</h1>
    <p class="mt-1.5 mb-0 text-text-muted text-sm">Gift boxes and sub-assemblies built from components.</p>
  </div>
  <div class="flex items-center gap-2.5 flex-wrap justify-end">
    <%= link_to "+ Add assembly", new_assembly_path(type: @tab == "sub" ? "Assembly" : "GiftAssembly"), class: "btn btn-primary" %>
  </div>
</div>

<div class="flex items-center gap-1 border-b border-border mb-5">
  <%= link_to "Gift assemblies", assemblies_path(tab: "gift"),
        class: "px-4 py-2.5 text-[13.5px] font-semibold -mb-px border-b-2 #{@tab == "gift" ? "border-accent text-text" : "border-transparent text-text-muted hover:text-text"}" %>
  <%= link_to "Sub-assemblies", assemblies_path(tab: "sub"),
        class: "px-4 py-2.5 text-[13.5px] font-semibold -mb-px border-b-2 #{@tab == "sub" ? "border-accent text-text" : "border-transparent text-text-muted hover:text-text"}" %>
</div>

<% if @tab == "sub" %>
  <%= render "assembly_table", assemblies: @assemblies, show_tier: false, add_type: "Assembly",
        empty_title: "No sub-assemblies yet", empty_body: "Add a reusable bundle of components to nest inside gift boxes." %>
<% else %>
  <%= render "assembly_table", assemblies: @assemblies, show_tier: true, add_type: "GiftAssembly",
        empty_title: "No gift assemblies yet", empty_body: "Add your first sellable gift box." %>
<% end %>
