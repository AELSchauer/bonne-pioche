<section class="mb-7.5 last:mb-0">
  <h2 class="m-0 mb-4 text-[15px] font-bold">Basics</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5" data-controller="field-toggle" data-field-toggle-show-when-value="GiftAssembly">
    <div>
      <span class="block mb-1.5 text-[13px] font-semibold text-text">Type</span>
      <% if @assembly.persisted? %>
        <input class="field-input field-input-readonly" type="text" readonly tabindex="-1"
               value="<%= AssembliesController::TYPES.fetch(@assembly.type || "Assembly", @assembly.type) %>">
        <p class="mt-1.5 text-xs text-text-faint">Assigned at creation; can't be changed.</p>
      <% else %>
        <% default_type = @selected_type.presence || AssembliesController::TYPES.keys.first %>
        <%= select_tag "assembly[type]", options_for_select(AssembliesController::TYPES.to_a.map { |value, label| [ label, value ] }, default_type),
              id: "assembly_type", class: "field-input",
              data: { field_toggle_target: "source", action: "change->field-toggle#toggle" } %>
        <p class="mt-1.5 text-xs text-text-faint">Gift assemblies are sellable boxes; assemblies can be nested as sub-assemblies.</p>
      <% end %>
    </div>

    <div>
      <%= f.label :name, "Assembly name", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.text_field :name, placeholder: "e.g. Autumn Harvest Box", class: "field-input", required: true %>
    </div>

    <div class="sm:col-span-2">
      <span class="block mb-1.5 text-[13px] font-semibold text-text">Primary SKU</span>
      <% if @assembly.persisted? %>
        <input class="field-input field-input-readonly" type="text" readonly tabindex="-1" value="<%= @assembly.sku %>">
        <p class="mt-1.5 text-xs text-text-faint">Assigned at creation; can't be changed.</p>
      <% else %>
        <% default_sku_prefix = @selected_sku_prefix.presence || AssembliesController::SKU_PREFIXES.keys.first %>
        <select class="field-input w-[180px]" id="assembly_sku_prefix" name="assembly[sku_prefix]">
          <% AssembliesController::SKU_PREFIXES.each do |code, label| %>
            <option value="<%= code %>" <%= "selected" if code == default_sku_prefix %>><%= "#{code} — #{label}" %></option>
          <% end %>
        </select>
        <p class="mt-1.5 text-xs text-text-faint">A unique number is assigned automatically when you save.</p>
      <% end %>
    </div>

    <% is_gift_assembly = @assembly.persisted? ? @assembly.is_a?(GiftAssembly) : true %>

    <div class="contents <%= "hidden" unless is_gift_assembly %>" data-field-toggle-target="field">
      <div>
        <label class="block mb-1.5 text-[13px] font-semibold text-text" for="assembly_msrp">MSRP ($)</label>
        <%= f.number_field :msrp, value: @assembly[:msrp_cents] && @assembly[:msrp_cents] / 100.0, min: 0, step: 0.01, id: "assembly_msrp", class: "field-input" %>
      </div>

      <div>
        <label class="block mb-1.5 text-[13px] font-semibold text-text" for="assembly_msrp_url">MSRP URL</label>
        <%= f.text_field :msrp_url, placeholder: "https://…", id: "assembly_msrp_url", class: "field-input" %>
      </div>

      <div>
        <%= f.label :tier, "Tier", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
        <%= f.select :tier, options_for_select(AssembliesController::TIERS.map { |value, label| [ label, value ] }, @assembly.tier),
              { include_blank: "Select tier" }, id: "assembly_tier", class: "field-input" %>
      </div>
    </div>

    <div>
      <%= f.label :status, "Status", class: "block mb-1.5 text-[13px] font-semibold text-text" %>
      <%= f.select :status, AssembliesController::STATUSES.map { |value, label| [ label, value ] }, {}, id: "assembly_status", class: "field-input" %>
      <p class="mt-1.5 text-xs text-text-faint">Draft &middot; Active &middot; Inactive &middot; Archived</p>
    </div>
  </div>
</section>

<section class="mb-7.5 last:mb-0">
  <h2 class="m-0 mb-4 text-[15px] font-bold">Attributes</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[22px] gap-y-5">
    <div class="sm:col-span-2">
      <span class="block mb-1.5 text-[13px] font-semibold text-text">Restrictions</span>
      <div class="flex flex-wrap gap-2">
        <% @restriction_options.each do |restriction_name| %>
          <label class="chip-toggle">
            <input type="checkbox" name="assembly[restrictions][]" value="<%= restriction_name.id %>"
                   <%= "checked" if @assembly.restrictions.any? { |r| r.restriction_name_id == restriction_name.id } %>>
            <span><%= restriction_name.name %></span>
          </label>
        <% end %>
      </div>
      <p class="mt-1.5 text-xs text-text-faint">Dietary or handling qualities this assembly satisfies.</p>
    </div>

    <div class="sm:col-span-2">
      <label class="block mb-1.5 text-[13px] font-semibold text-text" for="assembly_notes">Notes</label>
      <%= text_area_tag "assembly[notes]", nil, id: "assembly_notes", class: "field-input resize-y min-h-20", rows: 4 %>
    </div>
  </div>
</section>

<section class="mt-2" data-controller="nested-fields">
  <div class="flex items-center justify-between mb-4">
    <h2 class="m-0 text-[15px] font-bold">Components</h2>
    <button type="button" class="btn btn-secondary btn-sm" data-action="click->nested-fields#add">+ Add component</button>
  </div>

  <% active_line_items = @assembly.assembly_line_items.reject(&:marked_for_destruction?) %>

  <div class="overflow-x-auto <%= "hidden" unless active_line_items.any? %>" data-nested-fields-target="tableWrap">
    <table class="w-full min-w-[640px] border-collapse">
      <thead>
        <tr>
          <th class="text-left px-3 py-2 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border">Component / sub-assembly</th>
          <th class="text-left px-3 py-2 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border">Alternates</th>
          <th class="text-left px-3 py-2 text-xs font-bold uppercase tracking-wide text-text-faint bg-surface-alt border-b border-border w-28">Qty</th>
          <th class="px-3 py-2 bg-surface-alt border-b border-border w-20"></th>
        </tr>
      </thead>
      <tbody data-nested-fields-target="list">
        <%= f.fields_for :assembly_line_items do |li| %>
          <%= render "line_item_fields", li: li %>
        <% end %>
      </tbody>
    </table>
  </div>

  <p class="text-[13px] text-text-faint mt-2 <%= "hidden" if active_line_items.any? %>" data-nested-fields-target="empty">
    No components added yet.
  </p>

  <template data-nested-fields-target="template">
    <%= f.fields_for :assembly_line_items, AssemblyLineItem.new(line_item_options: [ LineItemOption.new ]), child_index: "NEW_RECORD" do |li| %>
      <%= render "line_item_fields", li: li %>
    <% end %>
  </template>

  <p class="mt-3 text-xs text-text-faint">Per-unit costing and CSV import/export aren't supported yet.</p>
</section>
